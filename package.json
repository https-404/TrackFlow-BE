{
    "name": "trackFlow-backend",
    "version": "1.0.0",
    "description": "Backend for TrackFlow application",
    "main": "TrackFlow.API/Program.cs",
    "scripts": {
        "run": "cd TrackFlow.API && dotnet run",
        "dev": "cd TrackFlow.API && dotnet watch run",
        "restore": "dotnet restore",
        "build": "dotnet build",
        "test": "cd TrackFlow.Tests && dotnet test",
        "migrate:update": "dotnet ef database update -p ../TrackFlow.Infrastructure -s .",
        "migrate:add": " dotnet ef migrations add -p ../TrackFlow.Infrastructure -s .",
        "migrate:remove": "dotnet ef migrations remove -p ../TrackFlow.Infrastructure -s ."
    }
}